# Khoá bảo mật app — tạo bằng: openssl rand -base64 42
SECRET_KEY=changeme-use-openssl-rand-base64-42

# ── Database local (docker compose) ──────────────────────────
# Hãy thêm dấu # vào trước các biến local này để vô hiệu hóa chúng (tránh hệ thống đọc nhầm)
# DB_HOST=db
# DB_PORT=5432
# DB_USER=chatbot
# DB_PASSWORD=chatbot123
# DB_NAME=chatbot

# Dùng khi deploy lên Render / managed database
# Ví dụ: postgresql://user:pass@host:5432/dbname
# Dùng khi deploy lên Render / managed database (Dán link Supabase vào đây)
DATABASE_URL_RAW=postgresql+asyncpg://postgres.reiwifnrnqkyjttrskjw:PUt4C!hYLF/ksbX@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?command_timeout=300


# ── Redis local (docker compose) ─────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Dùng khi deploy lên Render / managed key value
# Ví dụ: redis://default:pass@host:6379
REDIS_URL_RAW=

# ── Admin UI ──────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── RAG Chunking ──────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.30

# ── Tuỳ chọn ──────────────────────────────────────────────────
DEBUG=false
ENABLE_WEB_SEARCH=true
CORS_ORIGINS=["http://localhost","http://localhost:80","http://localhost:3000"]
PORT=8000
UVICORN_WORKERS=2

USE_R2_STORAGE=True
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET_NAME=chatbot-dvc-bucket