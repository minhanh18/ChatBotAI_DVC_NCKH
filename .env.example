# ============================================================
#  CHATBOT — Environment Variables
#  Copy file này thành .env và điền giá trị thực
# ============================================================

# ── BẮT BUỘC ─────────────────────────────────────────────────
# Lấy tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# (Tuỳ chọn) Nhiều key xoay vòng, cách nhau bằng dấu phẩy — cơ chế đã có sẵn trong code
GEMINI_API_KEYS=
TAVILY_API_KEY=

# Khoá bảo mật app — tạo bằng: openssl rand -base64 42
SECRET_KEY=changeme-use-openssl-rand-base64-42
# Khoá HMAC pseudonymise session_key (bắt buộc cho môi trường production)
# Tạo: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_HMAC_KEY=changeme-use-openssl-rand-base64-42
# Số token output tối đa (16384 cho Gemini Flash, tăng nếu câu trả lời bị cắt)
GEMINI_MAX_OUTPUT_TOKENS=16384

# ── Database local (docker compose) ──────────────────────────
DB_HOST=db
DB_PORT=5432
DB_USER=chatbot
DB_PASSWORD=chatbot123
DB_NAME=chatbot

# Dùng khi deploy lên Render / managed database
# Ví dụ: postgresql://user:pass@host:5432/dbname
DATABASE_URL_RAW=

# ── Redis local (docker compose) ─────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Dùng khi deploy lên Render / managed key value
# Ví dụ: redis://default:pass@host:6379
REDIS_URL_RAW=

# ── Admin UI ──────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── RAG Chunking ──────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.30

# ── Tuỳ chọn ──────────────────────────────────────────────────
DEBUG=false
ENABLE_WEB_SEARCH=true
CORS_ORIGINS=["http://localhost","http://localhost:80","http://localhost:3000"]
PORT=8000
UVICORN_WORKERS=2
